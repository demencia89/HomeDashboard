AUTH_USERNAME=user
AUTH_PASSWORD=change-me
AUTH_DISABLED=false
HOST=0.0.0.0
PORT=3000
# Bind Docker's published port. Keep 127.0.0.1 for local/VPN/reverse-proxy access.
# Use a LAN IP or 0.0.0.0 only when protected by firewall/VPN rules.
PORT_BIND_ADDRESS=127.0.0.1
CONFIG_HOST_DIR=./config
CONFIG_DIR=/config
LOCAL_FILE_ROOT=/config/files
